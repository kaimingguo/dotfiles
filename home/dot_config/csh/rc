# -*- mode: csh; tab-width: 8; indent-tabs-mode: t -*- ;; Emacs
# vi: set filetype=csh tabstop=8 shiftwidth=8 noexpandtab :: Vi/ViM

alias h		'history 25 \!* 25'
alias j		jobs -l
alias ls 	ls --color
alias la	ls -aF
alias lf	ls -FA
alias ll	ls -lAF

alias md	mkdir -p
alias rd 	rmdir
alias cd	pushd

if ( -e `where vim` ) then
	alias vi vim
endif

# These are normally set through /etc/login.conf.  You may override them here
# if wanted.
# set path = (/sbin /bin /usr/sbin /usr/bin /usr/local/sbin /usr/local/bin $HOME/bin)
# A righteous umask
# umask 22

setenv	EDITOR	vi
setenv 	VISUAL 	${EDITOR}
setenv	PAGER	less
setenv 	BLOCKSIZE M

if ( $?prompt ) then
	# An interactive shell -- set some stuff up
	set prompt = "%N@%m:%~ %# "
	set promptchars = "%#"

	set filec
	set history = 1000
	set savehist = (1000 merge)
	set autolist = ambiguous
	# Use history to aid expansion
	set autoexpand
	set autorehash
	#set mail = (/var/mail/$USER)
	if ( $?tcsh ) then
		set pushdsilent
		set pushdtohome

		bindkey "^W" backward-delete-word
		bindkey -k up history-search-backward
		bindkey -k down history-search-forward
	endif

	if ( $uid == 0 ) then
		unset savehist
	endif
endif

# include rc.d directory configuration
set _rcd_dir = "$home/.config/csh/rc.d"
if ( -d "$_rcd_dir" && -r "$_rcd_dir" ) then
	set _nonomatch_saved = $?nonomatch
	set nonomatch
	foreach rc_file ( "$_rcd_dir"/*.csh )
		if ( -f "$rc_file" && -r "$rc_file" ) then
			source "$rc_file"
		endif
	end
	unset rc_file
	if ( ! $_nonomatch_saved ) unset nonomatch
	unset _nonomatch_saved
endif
unset _rcd_dir
